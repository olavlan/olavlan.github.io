{
    "cSpell.language": "en,nb,es",
    "markdownlint.configFile": ".markdownlint.yml",
    "cSpell.import": [
        "cspell.config.yaml"
    ],
    "editor.codeActionsOnSave": {
        "source.fixAll.markdownlint": "explicit"
    },
    "[markdown]": {
        "editor.formatOnSave": true,
        "editor.formatOnPaste": true
    },
}